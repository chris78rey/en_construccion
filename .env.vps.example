# ==============================================================================
# Variables de Entorno - Da-TIca VPS Deployment
# ==============================================================================
# Copiar a .env antes de ejecutar: cp .env.vps.example .env
# ==============================================================================

# Dominio principal (sin https://, sin www.)
DOMAIN=da-tica.com

# Email para Let's Encrypt (para notificaciones de certificados)
LETSENCRYPT_EMAIL=admin@da-tica.com