---
import ThemeToggle from './ThemeToggle.vue';
import { nav } from '../data/site';

const { pathname = '/' } = Astro.props;
const isActive = (href) => (href === '/' ? pathname === '/' : pathname.startsWith(href));
---

<header class="site-header">
  <div class="container header-row">
    <a class="brand" href="/">
      <span class="brand-mark">Da</span>
      <span class="brand-sep">-</span>
      <span class="brand-accent">TIca</span>
    </a>

    <nav class="main-nav" aria-label="Navegación principal">
      {
        nav.map((item) => (
          <a href={item.href} class={isActive(item.href) ? 'is-active' : ''}>
            {item.label}
          </a>
        ))
      }
    </nav>

    <div class="header-actions">
      <a class="button button-secondary hide-mobile" href="mailto:crrb@da-tica.com?subject=Quiero%20informaci%C3%B3n">
        Contacto
      </a>
      <ThemeToggle client:load />
    </div>
  </div>
</header>
