---
import ThemeToggle from './ThemeToggle.vue';
import { nav, site } from '../data/site';

const { pathname = '/' } = Astro.props;
const isActive = (href) => (href === '/' ? pathname === '/' : pathname.startsWith(href));
---

<header class="site-header">
  <div class="container header-row">
    <a class="brand" href="/">
      <span class="brand-lockup">
        <span class="brand-name">{site.brand}</span>
        <span class="brand-subtitle">{site.tagline}</span>
      </span>
    </a>

    <nav class="main-nav" aria-label="Navegación principal">
      {
        nav.map((item) => (
          <a href={item.href} class={isActive(item.href) ? 'is-active' : ''}>
            {item.label}
          </a>
        ))
      }
    </nav>

    <div class="header-actions">
      <a
        class="button button-secondary hide-mobile"
        href={`mailto:${site.email}?subject=Quiero%20informaci%C3%B3n%20sobre%20Da-TIca`}
      >
        Solicitar información
      </a>
      <ThemeToggle client:load />
    </div>
  </div>
</header>