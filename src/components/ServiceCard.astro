---
const { index, label, title, description, bullets = [], href = '/' } = Astro.props;
---

<article class="service-card">
  <div class="service-top">
    <span class="service-index">{index}</span>
    <span class="service-pill">{label}</span>
  </div>
  <h3>{title}</h3>
  <p>{description}</p>
  <ul class="chip-list">
    {bullets.map((item) => <li>{item}</li>)}
  </ul>
  <a class="button button-secondary" href={href}>Ver detalle</a>
</article>
