---
import { site } from '../data/site';
---

<footer class="site-footer">
  <div class="container footer-grid">
    <div>
      <p class="footer-brand">{site.brand}</p>
      <p class="footer-copy">{site.description}</p>
      <p class="footer-note">Base visual moderna, rápida y lista para crecer con nuevas secciones o funciones.</p>
    </div>

    <div>
      <p class="footer-title">Contacto</p>
      <ul class="footer-list">
        <li><a href={`mailto:${site.email}`}>{site.email}</a></li>
        <li><a href={site.youtube} target="_blank" rel="noreferrer noopener">YouTube @Da-Tica</a></li>
        <li><a href={site.whatsapp} target="_blank" rel="noreferrer noopener">WhatsApp</a></li>
      </ul>
    </div>

    <div>
      <p class="footer-title">Servicios</p>
      <ul class="footer-list">
        <li><a href="/sitios-web/">Sitios web</a></li>
        <li><a href="/data-mining/">Data Mining</a></li>
        <li><a href="/cursos/">Cursos</a></li>
      </ul>
    </div>

    <div>
      <p class="footer-title">Enfoque</p>
      <ul class="footer-list">
        <li>Diseño más premium</li>
        <li>Comunicación más clara</li>
        <li>Base preparada para escalar</li>
      </ul>
    </div>
  </div>
</footer>