---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionIntro from '../components/SectionIntro.astro';
import ServiceCard from '../components/ServiceCard.astro';
import { premiumCapabilities, premiumStats, services, site } from '../data/site';
---

<BaseLayout
  title="Da-TIca | Sitios web, Data Mining y automatización aplicada"
  description={site.description}
  pathname={Astro.url.pathname}
>
  <section class="hero hero-home">
    <div class="container hero-grid">
      <div class="hero-copy">
        <span class="eyebrow">Tema premium en Astro</span>
        <h1>Un sitio más serio, más claro y con una presencia visual que sí se siente profesional.</h1>
        <p>
          Da-TIca reúne sitios web, análisis de datos y automatización aplicada en una propuesta visual
          más pulida, con mejor jerarquía, mejor percepción de marca y una base lista para crecer sin
          volver pesada la web.
        </p>

        <div class="button-row">
          <a class="button" href="/sitios-web/">Ver propuesta web</a>
          <a class="button button-secondary" href={`mailto:${site.email}?subject=Quiero%20una%20web%20premium`}>
            Solicitar información
          </a>
        </div>

        <div class="trust-row">
          <span class="trust-chip">Diseño premium</span>
          <span class="trust-chip">Rápido en Astro</span>
          <span class="trust-chip">Base escalable</span>
          <span class="trust-chip">Mensaje más comercial</span>
        </div>
      </div>

      <aside class="hero-preview glow-card">
        <div class="preview-header">
          <span class="stack-badge">Vista premium</span>
          <span class="mini-label">Astro + rendimiento</span>
        </div>

        <div class="preview-window">
          <div class="preview-line preview-line-lg"></div>
          <div class="preview-line preview-line-md"></div>
          <div class="preview-grid">
            <div class="preview-box"></div>
            <div class="preview-box"></div>
            <div class="preview-box"></div>
          </div>
        </div>

        <div class="metric-grid">
          {premiumStats.map((item) => (
            <article>
              <strong>{item.value}</strong>
              <span>{item.label}</span>
            </article>
          ))}
        </div>
      </aside>
    </div>
  </section>

  <section class="section section-soft">
    <div class="container stat-strip">
      {premiumStats.map((item) => (
        <article class="stat-card">
          <strong>{item.value}</strong>
          <span>{item.label}</span>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionIntro
        eyebrow="Servicios"
        title="Tres líneas con mejor presencia y mejor estructura"
        text="Cada línea queda presentada con más claridad para que el visitante entienda rápido qué recibe y por qué vale la pena avanzar."
      />

      <div class="card-grid card-grid-3">
        {services.map((service) => (
          <ServiceCard {...service} />
        ))}
      </div>
    </div>
  </section>

  <section class="section section-soft">
    <div class="container">
      <SectionIntro
        eyebrow="Lo que hace que se sienta mejor"
        title="El cambio no es solo visual; también mejora percepción, lectura y valor"
        text="La propuesta busca que el sitio se vea más caro, más limpio y más confiable sin perder velocidad ni simplicidad."
      />

      <div class="capability-grid">
        {premiumCapabilities.map((item) => (
          <article class="capability-card">
            <h3>{item.title}</h3>
            <p>{item.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container two-col-grid">
      <article class="featured-panel">
        <span class="eyebrow">Dirección visual</span>
        <h2>Menos apariencia de "página simple" y más sensación de producto profesional</h2>
        <p>
          La nueva home está pensada para vender mejor la percepción del servicio desde el primer scroll:
          mejor jerarquía visual, mejor distribución, mejores bloques y un cierre más convincente.
        </p>

        <ul class="detail-list">
          <li>Hero con más presencia y mejor composición</li>
          <li>Tarjetas y bloques con más profundidad visual</li>
          <li>Header y footer con acabado más serio</li>
          <li>Base CSS moderna para que las demás páginas hereden mejor estilo</li>
        </ul>
      </article>

      <article class="highlight-card">
        <p class="mini-label">Aplicación inmediata</p>
        <h3>Una base premium que luego puede crecer</h3>
        <p>
          Desde esta estructura ya se puede seguir con portafolio, casos, testimonios, blog, formularios,
          agenda, captación de leads o una landing especializada por servicio.
        </p>
        <a class="button" href="/data-mining/">Explorar servicios</a>
      </article>
    </div>
  </section>

  <section class="section">
    <div class="container closing-cta">
      <div>
        <span class="eyebrow">Siguiente nivel</span>
        <h2>La web ya puede empezar a sentirse como una plantilla de pago personalizada.</h2>
        <p>
          Con esta base, Da-TIca deja una imagen más fuerte y más moderna, lista para seguir refinándose por etapas.
        </p>
      </div>

      <div class="button-row">
        <a class="button" href="/sitios-web/">Ir a sitios web</a>
        <a class="button button-secondary" href={`mailto:${site.email}?subject=Quiero%20mejorar%20mi%20sitio`}>
          Continuar mejoras
        </a>
      </div>
    </div>
  </section>
</BaseLayout>