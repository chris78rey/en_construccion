---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionIntro from '../components/SectionIntro.astro';
import FaqAccordion from '../components/FaqAccordion.vue';
import { faqSitios } from '../data/site';
---

<BaseLayout
  title="Da-TIca | Sitios web profesionales"
  description="Sitios web profesionales con estructura clara, buena velocidad y base lista para crecer."
  pathname={Astro.url.pathname}
>
  <section class="hero page-hero">
    <div class="container hero-grid">
      <div class="hero-copy">
        <span class="eyebrow">Sitios web</span>
        <h1>Una página clara, profesional y lista para publicarse.</h1>
        <p>
          Esta línea está pensada para negocios, consultorios, emprendimientos y marcas personales
          que necesitan presencia digital sin complicarse con temas técnicos.
        </p>
        <div class="button-row">
          <a class="button" href="mailto:crrb@da-tica.com?subject=Quiero%20mi%20sitio%20web">Solicitar información</a>
          <a class="button button-secondary" href="/">Volver al inicio</a>
        </div>
      </div>

      <aside class="pricing-card">
        <p class="mini-label">Desde</p>
        <div class="price">6 USD<span>/mes</span></div>
        <ul class="detail-list compact">
          <li>Estructura profesional</li>
          <li>Diseño responsive</li>
          <li>SEO base y velocidad</li>
          <li>Ayuda para publicación</li>
        </ul>
      </aside>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionIntro
        eyebrow="Qué incluye"
        title="Lo que se busca resolver con esta línea"
        text="La meta no es solo tener una página bonita, sino una presencia útil para comunicar valor, facilitar contacto y transmitir confianza."
      />

      <div class="card-grid card-grid-3">
        <article class="info-card">
          <h3>Claridad comercial</h3>
          <p>El visitante entiende mejor qué se ofrece, para quién sirve y cómo dar el siguiente paso.</p>
        </article>
        <article class="info-card">
          <h3>Mejor imagen</h3>
          <p>El diseño transmite más profesionalismo que una sola página saturada o desordenada.</p>
        </article>
        <article class="info-card">
          <h3>Base escalable</h3>
          <p>La estructura permite crecer luego con blog, campañas, nuevas secciones o funciones adicionales.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section section-soft">
    <div class="container">
      <SectionIntro
        eyebrow="Proceso"
        title="Una implementación simple y progresiva"
        text="La propuesta está pensada para avanzar por etapas sin volver pesado el sitio ni complicar la publicación."
      />

      <div class="timeline-grid">
        <article class="step-card"><span>01</span><h3>Definir mensaje</h3><p>Se aclara oferta, servicio principal y objetivo de la página.</p></article>
        <article class="step-card"><span>02</span><h3>Diseñar estructura</h3><p>Se separan secciones para que el contenido respire y guíe al visitante.</p></article>
        <article class="step-card"><span>03</span><h3>Construir la versión inicial</h3><p>Se deja una página clara, rápida y bien presentada.</p></article>
        <article class="step-card"><span>04</span><h3>Publicar y crecer</h3><p>La base queda lista para hosting, VPS o futuras mejoras sin rehacer el proyecto.</p></article>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container two-col-grid">
      <article class="info-card accent-card">
        <p class="mini-label">Ventaja</p>
        <h3>Una web profesional sin volverla pesada</h3>
        <p>
          La estructura queda pensada para cargar rápido, verse bien y permitir bloques interactivos
          solo donde realmente aporten valor.
        </p>
      </article>

      <article class="info-card">
        <SectionIntro eyebrow="Preguntas frecuentes" title="Dudas comunes" text="Estas respuestas ayudan a que el visitante entienda mejor el enfoque." />
        <FaqAccordion items={faqSitios} client:visible />
      </article>
    </div>
  </section>
</BaseLayout>
