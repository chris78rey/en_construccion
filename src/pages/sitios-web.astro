---
// --- INICIO CAMBIO NUEVO ---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionIntro from '../components/SectionIntro.astro';
import FaqAccordion from '../components/FaqAccordion.vue';
import { faqSitios } from '../data/site';
---

<BaseLayout
  title={`Da-TIca | Sitios web profesionales`}
  description={`Sitios web profesionales con estructura clara, buena velocidad y base lista para crecer.`}
  pathname={Astro.url.pathname}
>
  <section class={`hero page-hero`}>
    <div class={`container hero-grid`}>
      <div class={`hero-copy`}>
        <span class={`eyebrow`}>Sitios web</span>
        <h1>Una página profesional para mostrar mejor un negocio, consultorio o marca personal.</h1>
        <p>
          Esta línea está pensada para quienes necesitan una presencia digital clara, ordenada y confiable,
          sin enredarse con lo técnico y con una imagen que ayude a generar mejores oportunidades.
        </p>
        <div class={`button-row`}>
          <a class={`button`} href={`mailto:crrb@da-tica.com?subject=Quiero%20mi%20sitio%20web`}>Solicitar información</a>
          <a class={`button button-secondary`} href={`/`}>Volver al inicio</a>
        </div>
      </div>

      <aside class={`pricing-card`}>
        <p class={`mini-label`}>Desde</p>
        <div class={`price`}>6 USD<span>/mes</span></div>
        <ul class={`detail-list compact`}>
          <li>Diseño profesional</li>
          <li>Adaptación a celular</li>
          <li>Velocidad y SEO base</li>
          <li>Apoyo para publicación</li>
        </ul>
      </aside>
    </div>
  </section>

  <section class={`section`}>
    <div class={`container`}>
      <SectionIntro
        eyebrow={`Qué aporta`}
        title={`Una web que no solo se ve bien, también ayuda a comunicar mejor`}
        text={`El objetivo es que la persona que visite la página entienda rápido qué se ofrece, por qué vale la pena y cómo ponerse en contacto.`}
      />

      <div class={`card-grid card-grid-3`}>
        <article class={`info-card`}>
          <h3>Más confianza</h3>
          <p>Una buena presentación digital ayuda a que el negocio se perciba más serio, ordenado y profesional.</p>
        </article>
        <article class={`info-card`}>
          <h3>Más claridad</h3>
          <p>El contenido se organiza para que el visitante entienda mejor el servicio y no se pierda entre demasiada información.</p>
        </article>
        <article class={`info-card`}>
          <h3>Más posibilidad de crecer</h3>
          <p>La base queda lista para añadir nuevas secciones, campañas, formularios o mejoras en etapas posteriores.</p>
        </article>
      </div>
    </div>
  </section>

  <section class={`section section-soft`}>
    <div class={`container`}>
      <SectionIntro
        eyebrow={`Proceso`}
        title={`Una ruta simple para pasar de la idea a una página publicada`}
        text={`Se trabaja por etapas para que el resultado sea claro, funcional y fácil de mantener.`}
      />

      <div class={`timeline-grid`}>
        <article class={`step-card`}><span>01</span><h3>Entender el servicio</h3><p>Se define qué se ofrece, a quién va dirigido y cuál es el mensaje principal.</p></article>
        <article class={`step-card`}><span>02</span><h3>Organizar el contenido</h3><p>Se estructura la información para que la página guíe mejor al visitante.</p></article>
        <article class={`step-card`}><span>03</span><h3>Construir la versión inicial</h3><p>Se prepara una web clara, rápida y bien presentada para comenzar con fuerza.</p></article>
        <article class={`step-card`}><span>04</span><h3>Publicar y mejorar</h3><p>Luego se puede crecer con nuevas secciones, funciones o campañas según la necesidad.</p></article>
      </div>
    </div>
  </section>

  <section class={`section`}>
    <div class={`container two-col-grid`}>
      <article class={`info-card accent-card`}>
        <p class={`mini-label`}>Ventaja</p>
        <h3>Una web profesional sin hacer pesado el proyecto</h3>
        <p>
          La idea es contar con una página moderna, rápida y agradable de recorrer,
          con espacio para incorporar funciones extra solo cuando realmente aporten valor.
        </p>
      </article>

      <article class={`info-card`}>
        <SectionIntro eyebrow={`Preguntas frecuentes`} title={`Dudas comunes`} text={`Estas respuestas ayudan a comprender mejor cómo funciona esta línea de servicio.`} />
        <FaqAccordion items={faqSitios} client:visible />
      </article>
    </div>
  </section>
</BaseLayout>
// --- FIN CAMBIO NUEVO ---