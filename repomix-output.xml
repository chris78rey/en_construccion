<file path="src/layouts/BaseLayout.astro">
---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

const {
  title = 'Da-TIca',
  description = 'Sitios web, Data Mining y soluciones digitales aplicadas',
  pathname = '/',
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#081120" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={new URL(pathname, Astro.site)} />
    <script is:inline>
      (() => {
        const key = 'datica-theme';
        const saved = localStorage.getItem(key);
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        const theme = saved || (prefersDark ? 'dark' : 'light');
        document.documentElement.dataset.theme = theme;
      })();
    </script>
  </head>
  <body>
    <div class="page-shell">
      <Header pathname={pathname} />
      <main>
        <slot />
      </main>
      <Footer />
    </div>
  </body>
</html>
</file>

