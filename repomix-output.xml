</file>

<file path="deploy/Caddyfile">
# ==============================================================================
# Caddyfile - Da-TIca VPS
# ==============================================================================
# HTTPS automático: Caddy obtiene y renueva certificados Let's Encrypt
# Redirige HTTP -> HTTPS automáticamente
# ==============================================================================

{
    admin off
    email {$LETSENCRYPT_EMAIL}
    storage file_system /data
}

# ------------------------------------------------------------------------------
# Redirección www -> dominio principal (permanent)
# ------------------------------------------------------------------------------
www.{$DOMAIN} {
    redir https://{$DOMAIN}{uri} permanent
}

# ------------------------------------------------------------------------------
# Dominio principal con HTTPS
# ------------------------------------------------------------------------------
{$DOMAIN} {
    # Compresión para mejor performance
    encode zstd gzip

    # Headers de seguridad
    header {
        X-Content-Type-Options nosniff
        X-Frame-Options DENY
        Referrer-Policy strict-origin-when-cross-origin
        X-XSS-Protection 1; mode=block
        Strict-Transport-Security max-age=31536000; includeSubDomains
    }

    # Logging a stdout (visible con docker compose logs)
    log {
        output stdout
        format console
    }

    # Proxy inverso al contenedor web (puerto interno 8080)
    reverse_proxy web:8080
}
</file>

<file path="docker-compose.vps.yml">
# ==============================================================================
# Da-TIca VPS Deployment - Docker Compose with Caddy (HTTPS automatico)
# ==============================================================================
# Uso: docker compose -f docker-compose.vps.yml up -d --build
# Requiere: Puertos 80 y 443 abiertos, dominio apuntando al VPS
# ==============================================================================

services:
  # ---------------------------------------------------------------------------
  # Servicio Web - Nginx sirviendo sitio estático en puerto 8080
  # ---------------------------------------------------------------------------
  web:
    container_name: datica-web
    build:
      context: ./web
      dockerfile: Dockerfile
    image: datica-portal-web:1.0.0
    restart: unless-stopped
    expose:
      - '8080'
    networks:
      - datica-web
    healthcheck:
      test: ['CMD', 'wget', '-qO-', 'http://127.0.0.1:8080/']
      interval: 30s
      timeout: 5s
      retries: 3
      start_period: 10s

  # ---------------------------------------------------------------------------
  # Proxy Caddy - HTTPS automático, certificados, redirección HTTP->HTTPS
  # ---------------------------------------------------------------------------
  caddy:
    image: caddy:2-alpine
    container_name: datica-caddy
    restart: unless-stopped
    depends_on:
      - web
    ports:
      - '80:80'
      - '443:443'
      - '443:443/udp'
    environment:
      - DOMAIN=${DOMAIN:-da-tica.com}
      - LETSENCRYPT_EMAIL=${LETSENCRYPT_EMAIL:-admin@da-tica.com}
    volumes:
      - ./deploy/Caddyfile:/etc/caddy/Caddyfile:ro
      - caddy_data:/data
      - caddy_config:/config
    networks:
      - datica-web

networks:
  datica-web:
    driver: bridge

volumes:
  caddy_data:
  caddy_config:
</file>

