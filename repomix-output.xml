# ==============================================================================
# Da-TIca - Docker Compose para Coolify
# ==============================================================================
# Configuración simple: Coolify maneja el proxy Traefik automáticamente.
# En Coolify, configurar dominios: https://da-tica.com:8080, https://www.da-tica.com:8080
# ==============================================================================

services:
  web:
    build:
      context: ./web
      dockerfile: Dockerfile
    image: da-tica_portal_web:1.0.0
    restart: unless-stopped
    expose:
      - '8080'
    healthcheck:
      test:
        - CMD
        - wget
        - '-qO-'
        - 'http://127.0.0.1:8080/'
      interval: 30s
      timeout: 5s
      retries: 3
      start_period: 20s
</file>

