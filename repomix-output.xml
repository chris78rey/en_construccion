<file path="src/pages/sitios-web.astro">
---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionIntro from '../components/SectionIntro.astro';
import FaqAccordion from '../components/FaqAccordion.vue';
import { faqSitios } from '../data/site';
---

<BaseLayout
  title="Da-TIca | Sitios web profesionales"
  description="Sitios web profesionales con estructura clara, rendimiento alto y base lista para crecer."
  pathname={Astro.url.pathname}
>
  <section class="hero page-hero">
    <div class="container hero-grid">
      <div class="hero-copy">
        <span class="eyebrow">Sitios web</span>
        <h1>Una página que inspire confianza y ayude a captar atención desde la primera visita.</h1>
        <p>
          Esta línea se enfoca en sitios para negocios, profesionales, consultorios o marcas personales
          que necesitan una presentación seria, clara y liviana.
        </p>
        <div class="button-row">
          <a class="button" href="mailto:crrb@da-tica.com?subject=Quiero%20un%20sitio%20web">Solicitar información</a>
          <a class="button button-secondary" href="/">Volver al inicio</a>
        </div>
      </div>

      <aside class="pricing-card">
        <p class="mini-label">Desde</p>
        <div class="price">6 USD<span>/mes</span></div>
        <ul class="detail-list compact">
          <li>Estructura profesional</li>
          <li>Diseño responsive</li>
          <li>SEO base y velocidad</li>
          <li>Ayuda para publicación</li>
        </ul>
      </aside>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionIntro
        eyebrow="Qué incluye"
        title="Lo que se busca resolver con esta línea"
        text="La meta no es solo tener una página bonita, sino una presencia útil para comunicar valor, contacto y confianza."
      />

      <div class="card-grid card-grid-3">
        <article class="info-card">
          <h3>Claridad comercial</h3>
          <p>El visitante entiende mejor qué se ofrece, para quién y cómo dar el siguiente paso.</p>
        </article>
        <article class="info-card">
          <h3>Mejor imagen</h3>
          <p>El diseño transmite más profesionalismo que una sola página saturada o desordenada.</p>
        </article>
        <article class="info-card">
          <h3>Base escalable</h3>
          <p>La estructura permite crecer luego con blog, campañas, landing pages o nuevas secciones.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section section-soft">
    <div class="container">
      <SectionIntro
        eyebrow="Proceso"
        title="Una implementación simple y progresiva"
        text="La propuesta está pensada para avanzar por etapas sin volver pesado el sitio ni complicar la publicación."
      />

      <div class="timeline-grid">
        <article class="step-card"><span>01</span><h3>Definir mensaje</h3><p>Se aclara oferta, servicio principal y objetivo de la página.</p></article>
        <article class="step-card"><span>02</span><h3>Diseñar estructura</h3><p>Se separan secciones para que el contenido respire y guíe al visitante.</p></article>
        <article class="step-card"><span>03</span><h3>Optimizar rendimiento</h3><p>Se usa Astro para cargar rápido y Vue solo en la interacción necesaria.</p></article>
        <article class="step-card"><span>04</span><h3>Publicar y crecer</h3><p>Se deja listo para hosting, VPS o futuras mejoras sin rehacer el proyecto.</p></article>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container two-col-grid">
      <article class="info-card accent-card">
        <p class="mini-label">Ventaja técnica</p>
        <h3>Una web profesional sin volverla pesada</h3>
        <p>
          Astro entrega HTML estático muy rápido y Vue se reserva para bloques interactivos puntuales.
          Eso ayuda a mantener buena experiencia y menor consumo de recursos.
        </p>
      </article>

      <article class="info-card">
        <SectionIntro eyebrow="Preguntas frecuentes" title="Dudas comunes" text="Estas respuestas ayudan a que el visitante entienda mejor el enfoque." />
        <FaqAccordion items={faqSitios} client:visible />
      </article>
    </div>
  </section>
</BaseLayout>
</file>

<file path="src/styles/global.css">
:root {
  color-scheme: light;
  --bg: #f4f7fb;
  --bg-soft: #eef4ff;
  --surface: rgba(255, 255, 255, 0.82);
  --surface-strong: #ffffff;
  --surface-accent: linear-gradient(145deg, rgba(37, 99, 235, 0.1), rgba(6, 182, 212, 0.08));
  --text: #0f172a;
  --muted: #5b6476;
  --line: rgba(15, 23, 42, 0.09);
  --line-strong: rgba(37, 99, 235, 0.18);
  --primary: #2563eb;
  --primary-strong: #1d4ed8;
  --primary-soft: rgba(37, 99, 235, 0.08);
  --shadow-lg: 0 24px 80px rgba(15, 23, 42, 0.12);
  --shadow-md: 0 14px 32px rgba(15, 23, 42, 0.08);
  --radius-xl: 28px;
  --radius-lg: 22px;
  --radius-md: 16px;
  --container: 1180px;
}

:root[data-theme='dark'] {
  color-scheme: dark;
  --bg: #07111f;
  --bg-soft: #0d1a2d;
  --surface: rgba(12, 21, 37, 0.82);
  --surface-strong: #0f172a;
  --surface-accent: linear-gradient(145deg, rgba(37, 99, 235, 0.18), rgba(6, 182, 212, 0.14));
  --text: #ecf5ff;
  --muted: #9aacbf;
  --line: rgba(148, 163, 184, 0.16);
  --line-strong: rgba(96, 165, 250, 0.28);
  --primary: #60a5fa;
  --primary-strong: #38bdf8;
  --primary-soft: rgba(96, 165, 250, 0.12);
  --shadow-lg: 0 28px 80px rgba(2, 6, 23, 0.48);
  --shadow-md: 0 16px 36px rgba(2, 6, 23, 0.3);
}

* {
  box-sizing: border-box;
}

html {
  scroll-behavior: smooth;
}

body {
  margin: 0;
  font-family: Inter, system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  color: var(--text);
  background:
    radial-gradient(circle at top left, rgba(37, 99, 235, 0.16), transparent 25%),
    radial-gradient(circle at 88% 12%, rgba(6, 182, 212, 0.12), transparent 24%),
    var(--bg);
  min-height: 100vh;
}

body,
a,
button,
input,
textarea {
  transition:
    background-color 0.2s ease,
    border-color 0.2s ease,
    color 0.2s ease,
    box-shadow 0.2s ease,
    transform 0.2s ease;
}

a {
  color: inherit;
  text-decoration: none;
}

img {
  display: block;
  max-width: 100%;
}

main {
  display: block;
}

.page-shell {
  min-height: 100vh;
}

.container {
  width: min(100% - 2rem, var(--container));
  margin: 0 auto;
}

.section {
  padding: 5rem 0;
}

.section-soft {
  background: linear-gradient(180deg, transparent, rgba(37, 99, 235, 0.03), transparent);
}

.site-header {
  position: sticky;
  top: 0;
  z-index: 40;
  backdrop-filter: blur(18px);
  background: color-mix(in srgb, var(--bg) 74%, transparent);
  border-bottom: 1px solid var(--line);
}

.header-row {
  min-height: 78px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1rem;
}

.brand {
  display: inline-flex;
  align-items: center;
  font-weight: 900;
  font-size: 1.15rem;
  letter-spacing: -0.04em;
}

.brand-mark,
.brand-sep {
  color: var(--text);
}

.brand-accent {
  color: var(--primary);
}

.main-nav {
  display: flex;
  flex-wrap: wrap;
  gap: 0.35rem;
  padding: 0.35rem;
  border-radius: 999px;
  border: 1px solid var(--line);
  background: var(--surface);
  box-shadow: var(--shadow-md);
}

.main-nav a {
  padding: 0.7rem 1rem;
  border-radius: 999px;
  color: var(--muted);
  font-size: 0.95rem;
  font-weight: 700;
}

.main-nav a:hover,
.main-nav a.is-active {
  color: var(--primary);
  background: var(--primary-soft);
}

.header-actions {
  display: flex;
  align-items: center;
  gap: 0.75rem;
}

.theme-toggle {
  width: 46px;
  height: 46px;
  border-radius: 50%;
  border: 1px solid var(--line);
  background: var(--surface);
  cursor: pointer;
  box-shadow: var(--shadow-md);
  font-size: 1rem;
}

.theme-toggle:hover,
.button:hover {
  transform: translateY(-1px);
}

.hero {
  padding: 5rem 0 4.25rem;
}

.hero-grid,
.two-col-grid,
.footer-grid {
  display: grid;
  gap: 1.5rem;
}

.hero-grid {
  grid-template-columns: 1.15fr 0.85fr;
  align-items: stretch;
}

.hero-copy h1,
.centered-block h1 {
  margin: 1rem 0 1rem;
  font-size: clamp(2.3rem, 5vw, 4.8rem);
  line-height: 0.98;
  letter-spacing: -0.05em;
  max-width: 14ch;
}

.hero-copy p,
.section-intro p,
.info-card p,
.glow-card p,
.footer-copy,
.centered-block p {
  color: var(--muted);
  font-size: 1.03rem;
  line-height: 1.75;
}

.hero-panel,
.glow-card,
.info-card,
.pricing-card,
.cta-banner,
.service-card,
.step-card {
  border: 1px solid var(--line);
  background: var(--surface);
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-lg);
}

.hero-panel,
.glow-card,
.pricing-card,
.info-card {
  padding: 1.6rem;
}

.glow-card,
.accent-card {
  background: var(--surface-accent), var(--surface);
}

.stack-badge,
.mini-label,
.service-pill,
.eyebrow,
.service-index {
  display: inline-flex;
  align-items: center;
  gap: 0.45rem;
  border-radius: 999px;
  font-weight: 800;
}

.eyebrow,
.stack-badge,
.service-pill,
.mini-label {
  border: 1px solid var(--line-strong);
  background: var(--primary-soft);
  color: var(--primary);
  padding: 0.55rem 0.9rem;
  font-size: 0.84rem;
}

.hero-points,
.detail-list,
.footer-list,
.chip-list {
  list-style: none;
  padding: 0;
  margin: 0;
}

.hero-points,
.detail-list {
  display: grid;
  gap: 0.8rem;
  margin-top: 1.4rem;
}

.hero-points li,
.detail-list li {
  position: relative;
  padding-left: 1.2rem;
}

.hero-points li::before,
.detail-list li::before {
  content: '•';
  position: absolute;
  left: 0;
  color: var(--primary);
  font-weight: 900;
}

.compact {
  gap: 0.55rem;
}

.button-row {
  display: flex;
  flex-wrap: wrap;
  gap: 0.9rem;
  margin-top: 1.4rem;
}

.button {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 0.55rem;
  padding: 0.95rem 1.25rem;
  border-radius: 999px;
  border: 1px solid transparent;
  background: linear-gradient(135deg, var(--primary), var(--primary-strong));
  color: white;
  font-weight: 800;
  box-shadow: var(--shadow-md);
}

.button-secondary {
  background: var(--surface);
  color: var(--text);
  border-color: var(--line);
}

.card-grid {
  display: grid;
  gap: 1.25rem;
}

.card-grid-3 {
  grid-template-columns: repeat(3, minmax(0, 1fr));
}

.service-card {
  padding: 1.5rem;
}

.service-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 0.75rem;
  margin-bottom: 1rem;
}

.service-index {
  width: 3rem;
  height: 3rem;
  justify-content: center;
  background: var(--surface-strong);
  border: 1px solid var(--line);
}

.service-card h3,
.info-card h3,
.glow-card h2,
.pricing-card h2,
.step-card h3,
.cta-banner h2,
.section-intro h2 {
  margin: 0 0 0.85rem;
  line-height: 1.08;
  letter-spacing: -0.03em;
}

.service-card h3,
.info-card h3,
.glow-card h2,
.pricing-card h2,
.cta-banner h2,
.section-intro h2 {
  font-size: clamp(1.45rem, 2.8vw, 2.45rem);
}

.service-card p {
  color: var(--muted);
  margin-bottom: 1rem;
}

.chip-list {
  display: flex;
  flex-wrap: wrap;
  gap: 0.55rem;
  margin-bottom: 1.15rem;
}

.chip-list li {
  padding: 0.45rem 0.75rem;
  border: 1px solid var(--line);
  border-radius: 999px;
  color: var(--muted);
  background: var(--surface-strong);
  font-size: 0.92rem;
}

.section-intro {
  max-width: 760px;
  margin-bottom: 2rem;
}

.section-intro.center {
  margin-inline: auto;
  text-align: center;
}

.metric-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 0.9rem;
  margin-top: 1.3rem;
}

.metric-grid.single-column {
  grid-template-columns: 1fr;
}

.metric-grid article,
.step-card {
  padding: 1rem;
  border-radius: var(--radius-md);
  border: 1px solid var(--line);
  background: color-mix(in srgb, var(--surface-strong) 86%, transparent);
}

.metric-grid strong,
.step-card span {
  display: block;
  font-size: 1.05rem;
  margin-bottom: 0.2rem;
}

.metric-grid span,
.step-card p {
  color: var(--muted);
}

.two-col-grid {
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.cta-banner {
  padding: 1.75rem;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1rem;
}

.pricing-card {
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.price {
  font-size: clamp(2.6rem, 6vw, 4.4rem);
  font-weight: 900;
