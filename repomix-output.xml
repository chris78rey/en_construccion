<file path="deploy/Caddyfile">
# ==============================================================================
# Caddyfile - Da-TIca VPS
# ==============================================================================
# HTTPS automático: Caddy obtiene y renueva certificados Let's Encrypt
# Redirige HTTP -> HTTPS automáticamente
# ==============================================================================

{
    admin off
    email {$LETSENCRYPT_EMAIL}
    storage file_system /data
}

# ------------------------------------------------------------------------------
# Redirección www -> dominio principal (permanent)
# ------------------------------------------------------------------------------
www.{$DOMAIN} {
    redir https://{$DOMAIN}{uri} permanent
}

# ------------------------------------------------------------------------------
# Dominio principal con HTTPS
# ------------------------------------------------------------------------------
{$DOMAIN} {
    # Compresión para mejor performance
    encode zstd gzip

    # Headers de seguridad
    header {
        X-Content-Type-Options nosniff
        X-Frame-Options DENY
        Referrer-Policy strict-origin-when-cross-origin
        X-XSS-Protection 1; mode=block
        Strict-Transport-Security max-age=31536000; includeSubDomains
    }

    # Logging a stdout (visible con docker compose logs)
    log {
        output stdout
        format console
    }

    # Proxy inverso al contenedor web (puerto interno 8080)
    reverse_proxy web:8080
}
</file>

<file path="docker-compose.vps.yml">
# ==============================================================================
# Da-TIca VPS Deployment - Docker Compose with Caddy (HTTPS automatico)
# ==============================================================================
# Uso: docker compose -f docker-compose.vps.yml up -d --build
# Requiere: Puertos 80 y 443 abiertos, dominio apuntando al VPS
# ==============================================================================

services:
  # ---------------------------------------------------------------------------
  # Servicio Web - Nginx sirviendo sitio estático en puerto 8080
  # ---------------------------------------------------------------------------
  web:
    container_name: datica-web
    build:
      context: ./web
      dockerfile: Dockerfile
    image: datica-portal-web:1.0.0
    restart: unless-stopped
    expose:
      - '8080'
    networks:
      - datica-web
    healthcheck:
      test: ['CMD', 'wget', '-qO-', 'http://127.0.0.1:8080/']
      interval: 30s
      timeout: 5s
      retries: 3
      start_period: 10s

  # ---------------------------------------------------------------------------
  # Proxy Caddy - HTTPS automático, certificados, redirección HTTP->HTTPS
  # ---------------------------------------------------------------------------
  caddy:
    image: caddy:2-alpine
    container_name: datica-caddy
    restart: unless-stopped
    depends_on:
      - web
    ports:
      - '80:80'
      - '443:443'
      - '443:443/udp'
    environment:
      - DOMAIN=${DOMAIN:-da-tica.com}
      - LETSENCRYPT_EMAIL=${LETSENCRYPT_EMAIL:-admin@da-tica.com}
    volumes:
      - ./deploy/Caddyfile:/etc/caddy/Caddyfile:ro
      - caddy_data:/data
      - caddy_config:/config
    networks:
      - datica-web

networks:
  datica-web:
    driver: bridge

volumes:
  caddy_data:
  caddy_config:
</file>

<file path="Dockerfile">
FROM node:22-alpine AS builder
WORKDIR /app
COPY package.json ./
RUN npm install
COPY . .
RUN npm run build

FROM nginx:1.27-alpine
RUN rm -f /etc/nginx/conf.d/default.conf
COPY nginx/default.conf /etc/nginx/conf.d/default.conf
COPY --from=builder /app/dist /usr/share/nginx/html
EXPOSE 8080
HEALTHCHECK --interval=30s --timeout=3s --start-period=10s --retries=3 CMD wget -qO- --timeout=2 http://127.0.0.1:8080/ >/dev/null 2>&1 || exit 1
CMD ["nginx", "-g", "daemon off;"]
</file>

<file path="nginx/default.conf">
server {
  listen 8080;
  server_name _;

  root /usr/share/nginx/html;
  index index.html;

  client_max_body_size 4m;

  location / {
    try_files $uri $uri/ =404;
  }

  location ~* \.html?$ {
    add_header Cache-Control "no-cache, must-revalidate";
  }

  location ~* \.(?:css|js|json|png|jpg|jpeg|svg|gif|ico|webp|woff2?|ttf)$ {
    try_files $uri =404;
    access_log off;
    add_header Cache-Control "public, max-age=604800, immutable";
  }

  location ~ /\.
  {
    deny all;
    access_log off;
    log_not_found off;
  }

  add_header X-Content-Type-Options nosniff;
  add_header X-Frame-Options DENY;
  add_header Referrer-Policy "strict-origin-when-cross-origin";

  access_log /var/log/nginx/access.log;
  error_log /var/log/nginx/error.log warn;
}
</file>

